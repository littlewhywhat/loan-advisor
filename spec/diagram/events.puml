@startuml finance-events

enum EventStatus {
  ACTIVE
  ARCHIVED
}

entity Event {
  * id : uuid <<PK>>
  --
  * date : date
  * status : EventStatus
}

entity TakeMortgage {
  * rental : boolean
}

entity TakePersonalLoan {
}

entity AddAsset {
}

entity AddIncome {
}

entity AddExpense {
}

entity ManualCorrection {
  * changes : jsonb
}

entity RepayLoan {
  * liabilityId : uuid <<FK>>
  * repaymentAmount : MoneyAmount
  * strategy : reduce_payment | reduce_term
}

Event <|-- TakeMortgage
Event <|-- TakePersonalLoan
Event <|-- AddAsset
Event <|-- AddIncome
Event <|-- AddExpense
Event <|-- ManualCorrection
Event <|-- RepayLoan

TakeMortgage "1" *-- "1" Mortgage
TakeMortgage "1" *-- "1" Flat
TakeMortgage "1" *-- "1" Expense
TakeMortgage "0..1" *-- "1" Income : if rental

TakePersonalLoan "1" *-- "1" Loan
TakePersonalLoan "1" *-- "1" Cash
TakePersonalLoan "1" *-- "1" Expense

AddAsset "1" *-- "1" Asset

AddIncome "1" *-- "1" Income
AddExpense "1" *-- "1" Expense

RepayLoan "1" --> "1" Liability : targets

@enduml
