@startuml finance-events

enum EventStatus {
  ACTIVE
  ARCHIVED
}

entity Event {
  * id : uuid <<PK>>
  --
  * date : date
  * status : EventStatus
}

note right of Event
  Stored as an insertion-ordered map
  keyed by id. Preserves creation order
  for deterministic processing while
  allowing O(1) lookup for editing.
end note

entity TakeMortgage {
  * rental : boolean
  allocations : CashAllocation[]
}

entity TakePersonalLoan {
}

entity AddAsset {
}

entity AddIncome {
}

entity AddExpense {
}

entity ManualCorrection {
  * changes : jsonb
}

entity RepayLoan {
  * liabilityId : uuid <<FK>>
  * expenseId : uuid <<FK>>
  * repaymentAmount : MoneyAmount
  * strategy : reduce_payment | reduce_term
  allocations : CashAllocation[]
  --
  * newPrincipal : MoneyAmount
  * newStartDate : date
  * newEndDate : date
  * newMonthlyPayment : MoneyAmount
}

entity BuyAsset {
  * allocations : CashAllocation[]
  forLiving : boolean
  removeExpenseId : uuid <<FK>>
}

Event <|-- TakeMortgage
Event <|-- TakePersonalLoan
Event <|-- AddAsset
Event <|-- AddIncome
Event <|-- AddExpense
Event <|-- ManualCorrection
Event <|-- RepayLoan
Event <|-- BuyAsset

TakeMortgage "1" *-- "1" Mortgage
TakeMortgage "1" *-- "1" Flat
TakeMortgage "1" *-- "1" Expense
TakeMortgage "0..1" *-- "1" Income : if rental
TakeMortgage "1" *-- "0..*" CashAllocation

TakePersonalLoan "1" *-- "1" Loan
TakePersonalLoan "1" *-- "1" Cash
TakePersonalLoan "1" *-- "1" Expense

AddAsset "1" *-- "1" Asset

AddIncome "1" *-- "1" Income
AddExpense "1" *-- "1" Expense

RepayLoan "1" --> "1" Liability : targets
RepayLoan "1" --> "1" Expense : updates
RepayLoan "1" *-- "0..*" CashAllocation

BuyAsset "1" *-- "1" Asset
BuyAsset "1" *-- "1..*" CashAllocation
BuyAsset "0..1" *-- "1" Expense : if forLiving
BuyAsset "0..1" --> "1" Expense : removes

@enduml
